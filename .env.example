# ============================================================
# EcoTrack AI — Variables de Entorno
# Copia este archivo como .env y completa los valores reales.
# NUNCA commitees el archivo .env
# ============================================================

# ---- apps/api (eco-track-ai-api.vercel.app) -----------------
# Clave de API de OpenAI (obtenerla en platform.openai.com)
OPENAI_API_KEY=sk-...

# Modelo a usar (gpt-4o-mini en dev, gpt-4o en prod)
OPENAI_MODEL=gpt-4o-mini

# Entorno de ejecución
NODE_ENV=production

# Origen permitido para CORS (URL exacta del frontend)
CORS_ORIGIN=https://eco-track-ai-web.vercel.app

# Puerto (Vercel lo inyecta automáticamente, solo necesario en local)
PORT=3001

# ---- apps/web (eco-track-ai-web.vercel.app) -----------------
# URL base del backend NestJS desplegado (sin slash final)
NEXT_PUBLIC_API_URL=https://eco-track-ai-api.vercel.app
